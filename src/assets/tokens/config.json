{
  "source": [
    "input/**/*.json"
  ],
  "platforms": {
    "scss": {
      "transformGroup": "scss",
      "transforms": [
        "attribute/cti",
        "name/cti/camel",
        "time/seconds",
        "content/icon",
        "size/px",
        "color/css"
      ],
      "files": [
        {
          "destination": "../../app/_partials/variables.scss",

          "format": "scss/variables"
        }
      ]
    },
    "javascript": {
      "transformGroup": "js",
      "files": [
        {
          "format": "javascript/es6",
          "destination": "lib/tokens.js"
        }
      ]
    }
  }
}
